{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/server.ts": {
      "includeFiles": "dist/**,server/_core/apple-developer-merchantid-domain-association,node_modules/**"
    }
  },
  "headers": [
    {
      "source": "./.well-known/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/text" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server"
    },
    {
      "source": "/payment/callback",
      "destination": "/api/server"
    },
    {
      "source": "/initialize-payment",
      "destination": "/api/server"
    },
    {
      "source": "/feed.xml",
      "destination": "/api/server"
    },
    {
      "source": "/.well-known",
      "destination": "/api/server"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}