{
  "buildCommand": "pnpm build",
  "outputDirectory": "dist/public",
  "functions": {
    "api/server.ts": {
      "includeFiles": "dist/**"
    }
  },
  "headers": [
    {
      "source": "./.well-known/(.*)",
      "headers": [
        { "key": "Content-Type", "value": "application/text" }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server"
    },
    {
      "source": "/payment/callback",
      "destination": "/api/server"
    },
    {
      "source": "/initialize-payment",
      "destination": "/api/server"
    },
    {
      "source": "/.well-known",
      "destination": "/.well-known/apple-developer-merchantid-domain-association"
    },
    {
      "source": "/.well-known/(.*)",
      "destination": "/.well-known/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}